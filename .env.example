# URL backend API. BẮT BUỘC ở production — frontend KHÔNG có chế độ mock/giả lập lúc chạy.
# Bỏ trống chỉ được chấp nhận cho build không có API (CI/static): khi đó cờ `isApiConfigured`
# (lib/api/client.ts) chỉ bỏ prerender SSG cây `/[locale]` + sitemap, KHÔNG bật dữ liệu mock.
# Thiếu biến này ở runtime → base URL rỗng, mọi lời gọi API hỏng (không có fallback).
# Production (Vercel): đặt bằng URL Render + /api, ví dụ:
#   https://thien-duc-website-backend.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# URL công khai của site — dùng cho canonical & JSON-LD (breadcrumb SEO).
# Production (Vercel): đặt bằng domain thật, ví dụ https://thien-duc-website-frontend.vercel.app
VITE_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error tracking (task →5) — DSN của project Sentry riêng cho frontend.
# DSN là khóa ingest-only, an toàn để nằm trong bundle client (không phải secret).
# Bỏ trống → không init, site chạy bình thường.
VITE_PUBLIC_SENTRY_DSN=